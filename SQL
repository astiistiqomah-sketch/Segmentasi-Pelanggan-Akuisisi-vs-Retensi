with first_orders as ( select
customer_id,
min(order_date) as first_order_date
from o.orders
group by customer_id
),
customer_segments AS (
select
customer_id,
CASE
WHEN EXTRACT(YEAR FROM first_order_date) = 2025 THEN
'NEW'
ELSE 'LOYAL'
END AS segment
FROM first_orders
)

SELECT
cs.segment,
COUNT(DISTINCT o.order_id) AS orders,
SUM(od.unit_price * od.quantity * (1 -
od.discount)) AS revenue
FROM
orders o
JOIN
order_details od ON o.order_id = od.order_id
JOIN
customer_segments cs ON o.customer_id =
cs.customer_id
WHERE
EXTRACT(YEAR FROM o.order_date) = 2025
GROUP BY
cs.segment;
